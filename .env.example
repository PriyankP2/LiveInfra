# ─── API Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Neo4j AuraDB ────────────────────────────────────────────────────────────
# Get from: https://console.neo4j.io → Your instance → Connect
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# For the web app (public anon key — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Upstash Redis ───────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Your database → REST API
UPSTASH_REDIS_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_TOKEN=

# ─── AI Providers ────────────────────────────────────────────────────────────
# Anthropic — primary RCA provider
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini — fallback when Anthropic quota exhausted
# Get from: https://aistudio.google.com → Get API key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Clerk ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your app → API Keys
CLERK_SECRET_KEY=sk_test_
CLERK_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── AWS (for scanner — set per-customer via Supabase, not here) ─────────────
# These are only needed for local scanner development/testing
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=     ← use IAM role assumption in production, not static keys
# AWS_SECRET_ACCESS_KEY= ← never commit real keys
